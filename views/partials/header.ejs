<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UAS E-Commerce</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-gray-50 text-gray-800 min-h-screen flex flex-col">

    <nav class="bg-blue-600 text-white shadow-md py-4 px-6 flex justify-between items-center">
        <a href="/" class="text-xl font-bold tracking-wide">DevE-Commerce</a>
        <div class="space-x-4">
            <% if (user) { %>
                <span class="text-sm bg-blue-700 px-3 py-1 rounded-full">Halo, <%= user.username %> (<%= user.role === 'seller' ? 'Penjual' : 'Pembeli' %>)</span>
                <% if (user.role === 'buyer') { %>
                    <a href="/products" class="hover:underline">Katalog Produk</a>
                <% } else if (user.role === 'seller') { %>
                    <a href="/seller/sales" class="hover:underline">Barang Terjual</a>
                <% } %>
                <a href="/auth/logout" class="bg-red-500 hover:bg-red-600 px-4 py-1.5 rounded text-sm font-semibold transition">Logout</a>
            <% } else { %>
                <a href="/auth/login" class="hover:underline text-sm font-medium">Login</a>
                <a href="/auth/register" class="bg-white text-blue-600 hover:bg-gray-100 px-4 py-1.5 rounded text-sm font-semibold transition">Daftar</a>
            <% } %>
        </div>
    </nav>

    <main class="flex-grow container mx-auto p-6">