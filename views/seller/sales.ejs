<%- include('../partials/header') %>

<div class="space-y-6">
    <div class="border-b pb-4 border-gray-200 flex justify-between items-center">
        <div>
            <h1 class="text-3xl font-extrabold tracking-tight text-gray-900">Dashboard Penjualan</h1>
            <p class="text-sm text-gray-500">Berikut adalah rekap semua produk Anda yang telah laku terjual.</p>
        </div>
        <a href="/seller/products/add" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors">
            <svg class="-ml-1 mr-2 h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Tambah Barang Baru
        </a>
    </div>

    <% if (typeof success_msg !== 'undefined' && success_msg.length > 0) { %>
        <div class="bg-green-50 border-l-4 border-green-400 p-4 rounded shadow-sm">
            <div class="flex">
                <div class="flex-shrink-0">
                    <svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                </div>
                <div class="ml-3">
                    <p class="text-sm text-green-700 font-medium"><%= success_msg %></p>
                </div>
            </div>
        </div>
    <% } %>

    <% if (typeof error_msg !== 'undefined' && error_msg.length > 0) { %>
        <div class="bg-red-50 border-l-4 border-red-400 p-4 rounded shadow-sm">
            <div class="flex">
                <div class="flex-shrink-0">
                    <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                    </svg>
                </div>
                <div class="ml-3">
                    <p class="text-sm text-red-700 font-medium"><%= error_msg %></p>
                </div>
            </div>
        </div>
    <% } %>

    <div class="bg-white shadow rounded-lg overflow-hidden border border-gray-200">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ID Transaksi</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Nama Produk</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Harga Satuan</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Jumlah</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Total Pendapatan</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Pembeli</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Waktu Terjual</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200 text-sm">
                <% if (salesData.length === 0) { %>
                    <tr>
                        <td colspan="7" class="px-6 py-10 text-center text-gray-500 font-medium">Belum ada barang yang terjual. Tambah semangat promosinya!</td>
                    </tr>
                <% } else { %>
                    <% salesData.forEach(sale => { %>
                        <tr class="hover:bg-gray-50">
                            <td class="px-6 py-4 whitespace-nowrap font-mono text-gray-600">#TRX-<%= sale.id %></td>
                            <td class="px-6 py-4 whitespace-nowrap font-semibold text-gray-900"><%= sale.nama_produk %></td>
                            <td class="px-6 py-4 whitespace-nowrap text-gray-600">Rp <%= sale.price.toLocaleString('id-ID') %></td>
                            <td class="px-6 py-4 whitespace-nowrap text-center font-medium"><%= sale.quantity %></td>
                            <td class="px-6 py-4 whitespace-nowrap font-bold text-green-600">Rp <%= (sale.price * sale.quantity).toLocaleString('id-ID') %></td>
                            <td class="px-6 py-4 whitespace-nowrap"><span class="bg-blue-50 text-blue-700 px-2.5 py-0.5 rounded-full text-xs font-medium"><%= sale.nama_pembeli %></span></td>
                            <td class="px-6 py-4 whitespace-nowrap text-gray-500 text-xs"><%= new Date(sale.created_at).toLocaleString('id-ID') %></td>
                        </tr>
                    <% }) %>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
    const socket = io();

    socket.on('produkTerjual', (data) => {
        const alertBox = document.createElement('div');
        alertBox.className = "fixed bottom-5 right-5 bg-green-600 text-white px-6 py-4 rounded-lg shadow-xl z-50 transition-all transform translate-y-0 animate-bounce";
        alertBox.innerHTML = `
            <p class="font-bold">🎉 Berhasil Terjual!</p>
            <p class="text-sm">${data.nama_pembeli} baru saja membeli ${data.quantity} pcs ${data.nama_produk}.</p>
            <button onclick="window.location.reload()" class="mt-2 text-xs bg-white text-green-700 font-bold px-2 py-1 rounded hover:bg-gray-100">Refresh Halaman</button>
        `;
        
        document.body.appendChild(alertBox);
    });
</script>

<%- include('../partials/footer') %>